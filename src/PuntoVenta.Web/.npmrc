# Supply-chain (pnpm v11 lee estos desde pnpm-workspace.yaml; aquí como respaldo/compat v10)
minimum-release-age=10080      # 7 días de cuarentena antes de instalar versiones nuevas
block-exotic-subdeps=true      # bloquea deps transitivas via git/tarball, solo registry
trust-policy=no-downgrade      # rechaza versiones que pierden provenance attestation

# Comportamiento de install
save-exact=true                # guarda versión exacta (sin ^ ~) al hacer pnpm add
strict-peer-dependencies=true  # falla si faltan peerDependencies
auto-install-peers=false       # no instala peers automáticamente
engine-strict=true             # falla si la versión de node no cumple package.json engines
