# Electron y electron-builder tienen subdeps con attestation perdida
# en cada release. No bloqueamos por trust downgrade en este sub-proyecto;
# el supply-chain check estricto se mantiene en PuntoVenta.Web.
trust-policy=permissive

# electron-builder requiere `@electron/node-gyp` via git, así que aquí no
# podemos bloquear exotic subdeps como sí hace PuntoVenta.Web.
block-exotic-subdeps=false

# 7 días de cuarentena antes de instalar versiones nuevas (igual que web).
minimum-release-age=10080

# Desactiva el check de deps antes de correr scripts. Electron y
# electron-winstaller traen postinstall que pnpm aún reporta como
# "ignored builds" pero ya corrimos a mano para descargar el binario.
verify-deps-before-run=false
